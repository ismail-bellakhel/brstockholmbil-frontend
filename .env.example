# ─── WordPress CMS ────────────────────────────────────────────────────────────
# URL of your WordPress installation on Miss Hosting (no trailing slash).
# Example: https://cms.brstockholmbil.se  or  https://brstockholmbil.se/cms
# Leave empty to run the frontend on mock/fallback data without WordPress.
NEXT_PUBLIC_WP_URL=

# Hostname only (no protocol, no path) of the WordPress server.
# Used by next/image to allow remote images from WP media library.
# Example: cms.brstockholmbil.se
WP_IMAGE_HOSTNAME=

# ─── Site URL ─────────────────────────────────────────────────────────────────
# The public-facing URL of this Next.js site (no trailing slash).
# Used for sitemap, canonical tags, and Open Graph URLs.
NEXT_PUBLIC_SITE_URL=https://www.brstockholmbil.se

# ─── On-demand revalidation ───────────────────────────────────────────────────
# Secret token shared between WordPress and Next.js.
# When a car or article is saved in WP, it calls /api/revalidate with this token
# so the page cache updates immediately instead of waiting for ISR timeout.
# Generate with: openssl rand -hex 32
# Must also be set in wp-config.php as NEXTJS_REVALIDATION_SECRET.
NEXTJS_REVALIDATION_SECRET=

# ─── Contact form (optional) ──────────────────────────────────────────────────
# If you wire up the contact form with Resend (https://resend.com):
RESEND_API_KEY=
CONTACT_EMAIL_TO=info@brstockholmbil.se

# ─── Ad monetization (optional) ───────────────────────────────────────────────
# Only needed if article page ads are activated in WordPress settings.
# These are managed via the WordPress Options Page → Annonsering tab.
# No values needed here — ad slot IDs live in WordPress, not in env vars.
